// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model Presentation {
  id            String      @id @default(uuid())
  title         String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastUsed      DateTime?
  status        String      @default("draft") // draft, published, archived
  metadata      Json?
  noteId        String?
  
  slides        Slide[]
  mediaItems    MediaItem[]
  note          Note?       @relation(fields: [noteId], references: [id])
  
  @@map("presentations")
}

model Slide {
  id             String      @id @default(uuid())
  presentationId String
  type           String      // text, media, richtext
  content        Json
  order          Int
  styling        Json
  animations     Json?
  transitions    Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  isActive       Boolean     @default(true)
  
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  textContent    TextContent?
  mediaContent   MediaContent?
  richTextContent RichTextContent?
  
  @@index([presentationId])
  @@index([type])
  @@index([order])
  @@map("slides")
}

model TextContent {
  id              String  @id @default(uuid())
  slideId         String  @unique
  text            String
  fontSize        String  @default("48px")
  fontFamily      String  @default("Arial, sans-serif")
  fontWeight      String  @default("normal")
  textAlign       String  @default("center")
  textColor       String  @default("#000000")
  backgroundColor String  @default("transparent")
  lineHeight      Float   @default(1.2)
  padding         Json
  textEffects     Json?
  typography      Json?
  
  slide           Slide   @relation(fields: [slideId], references: [id], onDelete: Cascade)
  
  @@map("text_content")
}

model MediaContent {
  id                String    @id @default(uuid())
  slideId           String    @unique
  mediaItemId       String
  displayMode       String    @default("fit")
  positioning       Json
  scaling           Json
  playbackSettings  Json
  overlays          Json?
  
  slide             Slide     @relation(fields: [slideId], references: [id], onDelete: Cascade)
  mediaItem         MediaItem @relation(fields: [mediaItemId], references: [id])
  
  @@map("media_content")
}

model RichTextContent {
  id          String  @id @default(uuid())
  slideId     String  @unique
  blocks      Json
  styling     Json
  formatting  Json
  version     String  @default("1.0.0")
  metadata    Json?
  
  slide       Slide   @relation(fields: [slideId], references: [id], onDelete: Cascade)
  
  @@map("rich_text_content")
}

model MediaItem {
  id           String    @id @default(uuid())
  filename     String
  originalName String
  path         String
  type         String    // "image", "video", "audio"
  mimeType     String
  size         Int
  duration     Int?      // For video/audio in seconds
  width        Int?      // For images/videos
  height       Int?      // For images/videos
  tags         String?   // JSON array of tags
  category     String?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastUsed     DateTime?
  
  presentations Presentation[]
  mediaContent  MediaContent[]
  
  @@index([type])
  @@index([category])
  @@map("media_items")
}

model SlideTemplate {
  id             String    @id @default(uuid())
  name           String
  type           String    // text, media, richtext
  defaultContent Json
  defaultStyling Json
  category       String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isPublic       Boolean   @default(false)
  
  @@index([type])
  @@index([category])
  @@map("slide_templates")
}

model SlideTheme {
  id           String    @id @default(uuid())
  name         String
  colorPalette Json
  typography   Json
  backgrounds  Json
  animations   Json?
  transitions  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDefault    Boolean   @default(false)
  
  @@map("slide_themes")
}



model Note {
  id          String @id @default(uuid())
  title       String
  content     String
  category    String?
  tags        String? // JSON array of tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  
  user          User? @relation(fields: [userId], references: [id])
  presentations Presentation[]
  
  @@index([userId])
  @@map("notes")
}



// User and Settings Models
model User {
  id          String @id @default(uuid())
  username    String @unique
  email       String? @unique
  fullName    String?
  role        String @default("operator") // "admin", "operator", "viewer"
  preferences String? // JSON user preferences
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLogin   DateTime?
  
  notes Note[]
  
  @@map("users")
}
